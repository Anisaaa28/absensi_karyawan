{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "buildCommand": "npm run build",
                "outputDirectory": "public"
            }
        },
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "runtime": "php8.2",
                "docRoot": "public"
            }
        }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/favicon.ico", "dest": "/favicon.ico" },
        { "src": "/robots.txt", "dest": "/robots.txt" },
        { "src": "/(.*?\\.(?:png|jpg|jpeg|gif|svg|webp|avif|woff2?|ttf|eot|css|js|mjs|map|xml|txt|pdf|ico))$", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_NAME": "Absensi Karyawan",
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:oclJ9XUelqh4WhsgHKa3lf7dvstoKd7Rx+fka6Xq94w=",
        "APP_URL": "https://absensi-karyawan-iota.vercel.app",
        "APP_TIMEZONE": "Asia/Jakarta",
        "APP_LOCALE": "id",
        "VERCEL": "1",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "info",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "aws-1-ap-southeast-2.pooler.supabase.com",
        "DB_PORT": "5432",
        "DB_DATABASE": "postgres",
        "DB_USERNAME": "postgres.eeiiaxugchvcwwlwrcar",
        "DB_PASSWORD": "EiMu_P*Xn#mxE9+",
        "DB_SCHEMA": "public, extensions",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "public",
        "BCRYPT_ROUNDS": "10"
    }
}
