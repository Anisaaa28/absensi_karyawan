{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "buildCommand": "npm run build",
                "outputDirectory": "public"
            }
        },
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4"
        }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/favicon.ico", "dest": "/favicon.ico" },
        { "src": "/robots.txt", "dest": "/robots.txt" },
        { "src": "/(.*?\\.(?:png|jpg|jpeg|gif|svg|webp|avif|woff2?|ttf|eot|css|js|mjs|map|json|xml|txt|pdf|ico))$", "dest": "/$1" },
        { "src": "/(.*)", "dest": "api/index.php" }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://absensi-karyawan-psi.vercel.app",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "debug",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "public",
        "BCRYPT_ROUNDS": "10",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views"
    }
}
