{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.0"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://absensi-karyawan.vercel.app",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "SESSION_DRIVER": "cookie",
        "CACHE_DRIVER": "array",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "public",
        "BCRYPT_ROUNDS": "10"
    }
}
